{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-ninja",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "base-ninja-debug",
      "hidden": true,
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "base-ninja-release",
      "hidden": true,
      "inherits": "base-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "sdk",
      "displayName": "SDK (Debug)",
      "description": "Build the public SDK libraries and their direct dependencies.",
      "inherits": "base-ninja-debug",
      "cacheVariables": {
        "CXXMCP_BUILD_SDK": "ON",
        "CXXMCP_BUILD_CLIENT": "OFF",
        "CXXMCP_BUILD_SERVER": "OFF",
        "CXXMCP_BUILD_EXAMPLES": "OFF",
        "CXXMCP_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "sdk-release",
      "displayName": "SDK (Release)",
      "description": "Build the public SDK libraries and their direct dependencies in Release mode.",
      "inherits": "base-ninja-release",
      "cacheVariables": {
        "CXXMCP_BUILD_SDK": "ON",
        "CXXMCP_BUILD_CLIENT": "OFF",
        "CXXMCP_BUILD_SERVER": "OFF",
        "CXXMCP_BUILD_EXAMPLES": "OFF",
        "CXXMCP_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "examples",
      "displayName": "Examples (Debug)",
      "description": "Build the example executables in Debug mode.",
      "inherits": "base-ninja-debug",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CXXMCP_BUILD_SDK": "ON",
        "CXXMCP_BUILD_CLIENT": "ON",
        "CXXMCP_BUILD_SERVER": "ON",
        "CXXMCP_BUILD_EXAMPLES": "ON",
        "CXXMCP_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "examples-release",
      "displayName": "Examples (Release)",
      "description": "Build the example executables in Release mode.",
      "inherits": "base-ninja-release",
      "cacheVariables": {
        "BUILD_TESTING": "ON",
        "CXXMCP_BUILD_SDK": "ON",
        "CXXMCP_BUILD_CLIENT": "ON",
        "CXXMCP_BUILD_SERVER": "ON",
        "CXXMCP_BUILD_EXAMPLES": "ON",
        "CXXMCP_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "tests",
      "displayName": "Tests (Debug)",
      "description": "Build the SDK with tests enabled.",
      "inherits": "base-ninja-debug",
      "cacheVariables": {
        "CXXMCP_BUILD_SDK": "ON",
        "CXXMCP_BUILD_CLIENT": "ON",
        "CXXMCP_BUILD_SERVER": "ON",
        "CXXMCP_BUILD_EXAMPLES": "OFF",
        "CXXMCP_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "tests-release",
      "displayName": "Tests (Release)",
      "description": "Build the SDK with tests enabled in Release mode.",
      "inherits": "base-ninja-release",
      "cacheVariables": {
        "CXXMCP_BUILD_SDK": "ON",
        "CXXMCP_BUILD_CLIENT": "ON",
        "CXXMCP_BUILD_SERVER": "ON",
        "CXXMCP_BUILD_EXAMPLES": "OFF",
        "CXXMCP_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "tests-asan-ubsan",
      "displayName": "Tests (Linux Clang ASan/UBSan)",
      "description": "Build the test stack on Linux/Clang with AddressSanitizer and UndefinedBehaviorSanitizer enabled.",
      "inherits": "tests",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer -fno-sanitize-recover=all",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer -fno-sanitize-recover=all",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "tests-tsan",
      "displayName": "Tests (Linux Clang TSan)",
      "description": "Build the test stack on Linux/Clang with ThreadSanitizer enabled.",
      "inherits": "tests",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "sdk",
      "configurePreset": "sdk"
    },
    {
      "name": "sdk-release",
      "configurePreset": "sdk-release"
    },
    {
      "name": "examples",
      "configurePreset": "examples"
    },
    {
      "name": "examples-release",
      "configurePreset": "examples-release"
    },
    {
      "name": "tests",
      "configurePreset": "tests"
    },
    {
      "name": "tests-release",
      "configurePreset": "tests-release"
    },
    {
      "name": "tests-asan-ubsan",
      "configurePreset": "tests-asan-ubsan",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "tests-tsan",
      "configurePreset": "tests-tsan",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "testPresets": [
    {
      "name": "examples",
      "configurePreset": "examples",
      "filter": {
        "include": {
          "label": "examples"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "examples-release",
      "configurePreset": "examples-release",
      "filter": {
        "include": {
          "label": "examples"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-release",
      "configurePreset": "tests-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-blocking",
      "configurePreset": "tests",
      "filter": {
        "include": {
          "label": "release-blocking"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "sanitizer-asan-ubsan",
      "configurePreset": "tests-asan-ubsan",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "filter": {
        "include": {
          "label": "release-blocking"
        },
        "exclude": {
          "name": "package_smoke|interop_.*"
        }
      },
      "execution": {
        "timeout": 600
      },
      "output": {
        "outputOnFailure": true
      },
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=1:strict_string_checks=1:check_initialization_order=1",
        "UBSAN_OPTIONS": "print_stacktrace=1:halt_on_error=1"
      }
    },
    {
      "name": "sanitizer-tsan",
      "configurePreset": "tests-tsan",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "filter": {
        "include": {
          "label": "release-blocking"
        },
        "exclude": {
          "name": "package_smoke|interop_.*"
        }
      },
      "execution": {
        "timeout": 900
      },
      "output": {
        "outputOnFailure": true
      },
      "environment": {
        "TSAN_OPTIONS": "halt_on_error=1:second_deadlock_stack=1"
      }
    }
  ]
}
